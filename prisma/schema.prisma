// Gec…ôl…ô ‚ÄĒ istirah…ôt evl…ôri marketpleysi
// SQLite il…ô v1; sah…ôl…ôr Postgres-…ô birbaŇüa k√∂√ß√ľr√ľl…ô bil…ôn Ňü…ôkild…ô se√ßilib.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  role         String    @default("guest") // guest | host
  name         String
  email        String?   @unique
  phone        String?   @unique
  passwordHash String    @default("")
  provider     String    @default("email") // email | phone | google | apple
  createdAt    DateTime  @default(now())
  listings     Listing[]
  bookings     Booking[]
}

model Listing {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  region        String
  type          String
  pricePerNight Int
  rating        Float     @default(0)
  reviews       Int       @default(0)
  maxGuests     Int
  bedrooms      Int
  pool          Boolean   @default(false)
  amenities     String // JSON massiv: '["Manqal","Wi-Fi"]'
  hostName      String
  hostPhone     String    @default("")
  photo         String
  photos        String    @default("[]") // JSON massiv ‚ÄĒ qalereya
  lat           Float?    // enlik ‚ÄĒ x…ôrit…ô √ľ√ß√ľn
  lng           Float?    // uzunluq
  previousPrice Int?      // …ôvv…ôlki qiym…ôt ‚ÄĒ "qiym…ôt d√ľŇüd√ľ" niŇüanńĪ √ľ√ß√ľn
  priceUpdatedAt DateTime? // qiym…ôt …ôn son n…ô vaxt d…ôyiŇüdi
  status        String    @default("approved") // approved | pending | rejected
  owner         User?     @relation(fields: [ownerId], references: [id])
  ownerId       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  reviewList    Review[]
  views         ListingView[]

  @@index([region])
  @@index([status, createdAt])
  @@index([ownerId])
}

// Elan baxńĪŇülarńĪ ‚ÄĒ real "24 saatda N baxńĪŇü" sosial s√ľbutu √ľ√ß√ľn.
// viewerId il…ô t…ôkrar baxńĪŇülar 6 saat p…ônc…ôr…ôd…ô birl…ôŇüdirilir.
model ListingView {
  id        String   @id @default(cuid())
  listing   Listing  @relation(fields: [listingId], references: [id])
  listingId String
  viewerId  String
  createdAt DateTime @default(now())

  @@index([listingId, createdAt])
}

model Booking {
  id         String    @id @default(cuid())
  listing    Listing   @relation(fields: [listingId], references: [id])
  listingId  String
  user       User?     @relation(fields: [userId], references: [id])
  userId     String?
  checkIn    DateTime
  checkOut   DateTime
  guests     Int
  guestName  String
  guestPhone String
  total      Int
  deposit    Int
  code       String    @unique
  status     String    @default("pending") // pending | confirmed | cancelled
  expiresAt  DateTime? // pending rezervin tarix tutma m√ľdd…ôti (15 d…ôq)
  paidAt     DateTime?
  paymentRef String    @default("")
  refundedAt DateTime?
  refundRef  String    @default("")
  recoveryNotifiedAt DateTime? // t…ôrk edilmiŇü rezerv xatńĪrlatmasńĪ g√∂nd…ôrilib
  createdAt  DateTime  @default(now())

  @@index([listingId, checkIn])
  @@index([guestPhone])
  @@index([userId])
  @@index([status, expiresAt])
}

// R…ôy yalnńĪz t…ôsdiql…ônmiŇü rezervasiya kodu il…ô yazńĪlńĪr ‚ÄĒ
// "yalnńĪz qalan qonaqlarńĪn r…ôyl…ôri" v…ôdinin texniki t…ôminatńĪ.
model Review {
  id          String   @id @default(cuid())
  listing     Listing  @relation(fields: [listingId], references: [id])
  listingId   String
  bookingCode String   @unique
  guestName   String
  rating      Int
  text        String
  createdAt   DateTime @default(now())

  @@index([listingId, createdAt])
}

// Telefon OTP kodlarńĪ ‚ÄĒ yalnńĪz canlńĪ SMS rejimind…ô istifad…ô olunur.
model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}
