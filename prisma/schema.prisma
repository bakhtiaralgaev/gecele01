// Gecələ — istirahət evləri marketpleysi
// Neon Postgres (eu-central-1). Lokal, test və canlı — eyni motor.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Saytın normal işi: pooler-dən keçir. Serverless yüzlərlə qısa bağlantı
  // açır, Postgres isə ~100 tutur — PgBouncer onları birləşdirir.
  url = env("DATABASE_URL")
  // Migration-lar: pooler-siz. Prisma advisory lock işlədir, transaction
  // rejimindəki pooler onu qırır.
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  role         String    @default("guest") // guest | host
  name         String
  email        String?   @unique
  phone        String?   @unique
  passwordHash String    @default("")
  provider     String    @default("email") // email | phone | google | apple
  createdAt    DateTime  @default(now())
  listings     Listing[]
  bookings     Booking[]

  // Ev sahibinə ödəniş rekvizitləri. Bank inteqrasiyası təsdiqlənənə qədər
  // yalnız yığılır — pul hərəkəti payout adapteri ilə aparılacaq.
  payoutIban       String?
  payoutName       String? // hesab sahibinin adı (bankdakı kimi)
  payoutVerifiedAt DateTime?
}

model Listing {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  region        String
  type          String
  pricePerNight Int
  rating        Float     @default(0)
  reviews       Int       @default(0)
  maxGuests     Int
  bedrooms      Int
  pool          Boolean   @default(false)
  amenities     String // JSON massiv: '["Manqal","Wi-Fi"]'
  hostName      String
  hostPhone     String    @default("")
  photo         String
  photos        String    @default("[]") // JSON massiv — qalereya
  lat           Float?    // enlik — xəritə üçün
  lng           Float?    // uzunluq
  previousPrice Int?      // əvvəlki qiymət — "qiymət düşdü" nişanı üçün
  priceUpdatedAt DateTime? // qiymət ən son nə vaxt dəyişdi
  status        String    @default("approved") // approved | pending | rejected
  owner         User?     @relation(fields: [ownerId], references: [id])
  ownerId       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  reviewList    Review[]
  views         ListingView[]

  @@index([region])
  @@index([status, createdAt])
  @@index([ownerId])
}

// Elan baxışları — real "24 saatda N baxış" sosial sübutu üçün.
// viewerId ilə təkrar baxışlar 6 saat pəncərədə birləşdirilir.
model ListingView {
  id        String   @id @default(cuid())
  listing   Listing  @relation(fields: [listingId], references: [id])
  listingId String
  viewerId  String
  createdAt DateTime @default(now())

  @@index([listingId, createdAt])
}

model Booking {
  id         String    @id @default(cuid())
  listing    Listing   @relation(fields: [listingId], references: [id])
  listingId  String
  user       User?     @relation(fields: [userId], references: [id])
  userId     String?
  checkIn    DateTime
  checkOut   DateTime
  guests     Int
  guestName  String
  guestPhone String
  total      Int
  deposit    Int
  code       String    @unique
  status     String    @default("pending") // pending | confirmed | cancelled
  expiresAt  DateTime? // pending rezervin tarix tutma müddəti (15 dəq)
  paidAt     DateTime?
  paymentRef String    @default("")
  refundedAt DateTime?
  refundRef  String    @default("")
  recoveryNotifiedAt DateTime? // tərk edilmiş rezerv xatırlatması göndərilib
  createdAt  DateTime  @default(now())
  messages   Message[]
  payout     Payout?

  @@index([listingId, checkIn])
  @@index([guestPhone])
  @@index([userId])
  @@index([status, expiresAt])
}

// Rəy yalnız təsdiqlənmiş rezervasiya kodu ilə yazılır —
// "yalnız qalan qonaqların rəyləri" vədinin texniki təminatı.
model Review {
  id          String   @id @default(cuid())
  listing     Listing  @relation(fields: [listingId], references: [id])
  listingId   String
  bookingCode String   @unique
  guestName   String
  rating      Int
  text        String
  createdAt   DateTime @default(now())

  @@index([listingId, createdAt])
}

// Mesajlaşma — YALNIZ rezervasiyadan sonra. Hər söhbət bir booking-ə bağlıdır;
// yalnız həmin rezervin qonağı və elanın ev sahibi yaza bilər.
model Message {
  id        String   @id @default(cuid())
  booking   Booking  @relation(fields: [bookingId], references: [id])
  bookingId String
  sender    String // "guest" | "host"
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([bookingId, createdAt])
}

// Seçilmişlər — hesaba bağlı wishlist (cihazlar arası sinxron). Giriş edən
// istifadəçinin lokal seçimləri buraya birləşdirilir. listingId sadə mətndir
// (Message modeli kimi) — referatik əlaqə tələb olunmur.
model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// Ev sahibinə ödəniləcək məbləğ (payable).
// Beh Qoruması qaydası: beh qonaq evə GİRƏNƏ QƏDƏR platformada qalır —
// ona görə payout yalnız eligibleAt (giriş tarixi) çatandan sonra açılır.
// amount = beh − komissiya. Qalıq məbləği qonaq girişdə nağd ödəyir.
model Payout {
  id         String    @id @default(cuid())
  booking    Booking   @relation(fields: [bookingId], references: [id])
  bookingId  String    @unique
  hostUserId String? // elanın sahibi (Listing.ownerId); sahibsiz elanda null
  amount     Int // hosta çatan (AZN)
  commission Int // platformanın payı — xidmət haqqı (AZN)
  status     String    @default("pending") // pending | eligible | processing | paid | failed | cancelled
  eligibleAt DateTime // girişdən sonra ödənişə açılır
  paidAt     DateTime?
  ref        String    @default("") // bank əməliyyat referansı
  failure    String    @default("")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status, eligibleAt])
  @@index([hostUserId])
}

// Mühasibat izi (audit trail): hər pul hərəkəti bir sətir.
// Yalnız əlavə olunur — heç vaxt dəyişdirilmir/silinmir.
model LedgerEntry {
  id        String   @id @default(cuid())
  bookingId String
  kind      String // deposit_in | commission | host_payable | refund_out | payout_out
  amount    Int // AZN, həmişə müsbət
  ref       String   @default("")
  note      String   @default("")
  createdAt DateTime @default(now())

  @@index([bookingId, createdAt])
  @@index([kind, createdAt])
}

// Audit izi — kim, nə vaxt, nəyi dəyişdi. Yalnız append.
// Admin əməliyyatları və pul hərəkətləri buraya düşür. Mübahisə/fırıldaq
// araşdırmasında yeganə etibarlı mənbədir.
model AuditLog {
  id         String   @id @default(cuid())
  actor      String // "admin" | userId | "system" | "cron"
  actorType  String // admin | user | system
  action     String // listing.approve | booking.cancel | payout.paid ...
  targetType String // listing | booking | payout | user
  targetId   String
  meta       String   @default("") // JSON — əlavə kontekst
  ip         String   @default("")
  createdAt  DateTime @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([actor, createdAt])
  @@index([action, createdAt])
}

// Telefon OTP kodları — yalnız canlı SMS rejimində istifadə olunur.
model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}
