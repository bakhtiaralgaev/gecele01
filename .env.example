# Gecələ — nümunə konfiqurasiya. Bunu .env kimi kopyalayıb dəyərləri doldurun.

# Verilənlər bazası — Neon Postgres (eu-central-1 / Frankfurt).
# Lokal, test və canlı: eyni motor. Neon Console → Connect düyməsi.
#
#  DATABASE_URL       saytın işi     → "Connection pooling" AÇIQ  (hostda -pooler VAR)
#  DIRECT_URL         migration-lar  → "Connection pooling" BAĞLI (hostda -pooler YOX)
#  TEST_DATABASE_URL  testlər        → ayrıca `test` branch, pooler-siz
#
# ⚠️ TEST_DATABASE_URL production ilə eyni OLMAMALIDIR — testlər hər qaçışda
#    bazanı tam silir. tests/global-setup.ts bunu yoxlayır və eynidirsə dayanır.
DATABASE_URL="postgresql://USER:PAROL@ep-xxx-pooler.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PAROL@ep-xxx.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require"
TEST_DATABASE_URL="postgresql://USER:PAROL@ep-yyy.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Admin panel girişi — canlıda güclü parol qoyun
ADMIN_PASSWORD="change-me"

# Sessiya imzası — canlıda MƏCBURİ: openssl rand -hex 32
AUTH_SECRET=""

# Saytın canlı ünvanı (sitemap / OG / ödəniş callback / email üçün)
NEXT_PUBLIC_SITE_URL="https://gecele.az"

# Ödəniş — Payriff (boş: TEST rejim)
PAYRIFF_MERCHANT_ID=""
PAYRIFF_SECRET_KEY=""

# OAuth (boş: demo rejim)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_KEY_ID=""

# SMS OTP (boş: demo kodu 1234)
SMS_API_KEY=""
SMS_API_URL=""
SMS_SENDER="Gecele"

# E-poçt bildirişi (Resend; boş: demo/log)
RESEND_API_KEY=""
EMAIL_FROM="Gecələ <bildiris@gecele.az>"

# Şəkil saxlama (Vercel Blob; boş: lokal public/uploads — yalnız dev)
BLOB_READ_WRITE_TOKEN=""

# Analitika (boş: skript yüklənmir)
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""

# Cron gizli açarı — tərk edilmiş rezerv bərpası (/api/cron/abandoned).
# Vercel Cron çağıranda avtomatik "Authorization: Bearer <CRON_SECRET>" göndərir.
# Boş: dev-də sərbəst işləyir, prod-da endpoint 503 verir. Canlıda: openssl rand -hex 32
CRON_SECRET=""
