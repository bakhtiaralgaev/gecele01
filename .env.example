# Gecələ — nümunə konfiqurasiya. Bunu .env kimi kopyalayıb dəyərləri doldurun.

# Verilənlər bazası
#  - Lokal (dev): SQLite  →  file:./dev.db
#  - Canlı (Vercel): Postgres (Neon) + schema.prisma-da provider = "postgresql"
DATABASE_URL="file:./dev.db"

# Admin panel girişi — canlıda güclü parol qoyun
ADMIN_PASSWORD="change-me"

# Sessiya imzası — canlıda MƏCBURİ: openssl rand -hex 32
AUTH_SECRET=""

# Saytın canlı ünvanı (sitemap / OG / ödəniş callback / email üçün)
NEXT_PUBLIC_SITE_URL="https://gecele.az"

# Ödəniş — Payriff (boş: TEST rejim)
PAYRIFF_MERCHANT_ID=""
PAYRIFF_SECRET_KEY=""

# OAuth (boş: demo rejim)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_KEY_ID=""

# SMS OTP (boş: demo kodu 1234)
SMS_API_KEY=""
SMS_API_URL=""
SMS_SENDER="Gecele"

# E-poçt bildirişi (Resend; boş: demo/log)
RESEND_API_KEY=""
EMAIL_FROM="Gecələ <bildiris@gecele.az>"

# Şəkil saxlama (Vercel Blob; boş: lokal public/uploads — yalnız dev)
BLOB_READ_WRITE_TOKEN=""

# Analitika (boş: skript yüklənmir)
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""

# Cron gizli açarı — tərk edilmiş rezerv bərpası (/api/cron/abandoned).
# Vercel Cron çağıranda avtomatik "Authorization: Bearer <CRON_SECRET>" göndərir.
# Boş: dev-də sərbəst işləyir, prod-da endpoint 503 verir. Canlıda: openssl rand -hex 32
CRON_SECRET=""
