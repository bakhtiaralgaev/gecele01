{
  "name": "gecele-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3050",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start -p 3050",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@prisma/client": "^5.19.0",
    "@vercel/blob": "^2.5.0",
    "date-fns": "^4.4.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "next": "14.2.15",
    "next-pwa": "^5.6.0",
    "react": "18.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "18.3.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.4.2",
    "postcss": "^8.4.38",
    "prisma": "^5.19.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
